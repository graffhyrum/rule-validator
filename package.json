{
	"name": "@graff/rule-validator",
	"version": "0.0.1",
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"bin": {
		"rule-validator": "./dist/cli.js"
	},
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli.js"
	},
	"private": true,
	"scripts": {
		"build": "bun scripts/build.ts && bun run build:declaration",
		"build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json",
		"postbuild": "bun run --shell bun remove-buildinfo",
		"validate": "bun run src/cli.ts",
		"remove-buildinfo": "rm -rf tsconfig.types.tsbuildinfo",
		"dev": "bun run src/cli.ts",
		"test": "bun test",
		"test:coverage": "AGENT=1 bun test --coverage ",
		"typecheck": "tsc --noEmit",
		"check": "biome check .",
		"fix": "biome check --write .",
		"custom-hooks": "stepdown-rule && bun run dist/cli.js",
		"fastvet": "bun run build && bun typecheck && bun fix && bun run custom-hooks  && bun run test:coverage",
		"vet": "bun fastvet"
	},
	"dependencies": {
		"arktype": "^2.1.29",
		"commander": "^14.0.3",
		"glob": "^13.0.6",
		"picocolors": "^1.1.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.3",
		"@changesets/cli": "^2.29.8",
		"@types/bun": "^1.3.9",
		"@types/node": "^25.3.0"
	},
	"peerDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260219.1"
	}
}
