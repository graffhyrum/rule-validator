{
	"name": "@graff/rule-validator",
	"version": "0.0.1",
	"private": true,
	"bin": {
		"rule-validator": "./dist/cli.js"
	},
	"type": "module",
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": "./dist/index.js",
		"./cli": "./dist/cli.js"
	},
	"scripts": {
		"build": "bun scripts/build.ts && bun run build:declaration",
		"build:declaration": "tsc --emitDeclarationOnly --project tsconfig.types.json",
		"postbuild": "bun run --shell bun remove-buildinfo",
		"validate": "bun run src/cli.ts",
		"remove-buildinfo": "rm -rf tsconfig.types.tsbuildinfo",
		"dev": "bun run src/cli.ts",
		"test": "bun test",
		"test:coverage": "AGENT=1 bun run scripts/coverage-threshold.ts",
		"typecheck": "tsc --noEmit",
		"check": "bunx oxlint . && bunx oxfmt --check .",
		"fix": "bunx oxlint --fix . && bunx oxfmt .",
		"custom-hooks": "stepdown-rule analyze && bun run src/cli.ts ",
		"fastvet": "bun run build && bun typecheck && bun fix && bun run custom-hooks  && bun run test:coverage",
		"vet": "bun fastvet"
	},
	"dependencies": {
		"arktype": "^2.2.0",
		"commander": "^14.0.3",
		"glob": "^13.0.6",
		"picocolors": "^1.1.1",
		"typescript": "^5.9.3"
	},
	"devDependencies": {
		"@changesets/cli": "^2.30.0",
		"@types/bun": "^1.3.10",
		"@types/node": "^25.4.0",
		"oxfmt": "^0.38.0",
		"oxlint": "^1.53.0"
	},
	"peerDependencies": {
		"@typescript/native-preview": "^7.0.0-dev.20260219.1"
	}
}
